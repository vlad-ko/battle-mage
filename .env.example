# Slack App credentials (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Anthropic API key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub fine-grained PAT (scoped to target repo, READ-ONLY for code)
# Permissions: Contents (read), Issues (read/write), Pull requests (read), Metadata (read)
GITHUB_PAT_BM=github_pat_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# Vercel KV (auto-configured when you create a KV store in Vercel dashboard)
# These are set automatically by Vercel when you link a KV database.
# For local dev, copy them from your Vercel project settings.
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Sentry (optional — for structured log capture + error tracking)
# Without SENTRY_DSN the SDK is a silent no-op. With it, structured
# events (agent_start, agent_complete, token usage, errors) flow to
# Sentry.io — the only reliable way to capture logs from Next.js
# `after()` callbacks on Vercel. See docs/observability.md for details.
SENTRY_DSN=
# Optional overrides (defaults work for most cases):
# SENTRY_TRACES_SAMPLE_RATE=1
